PORT=3001

# 逗号分隔的允许跨域来源，生产环境务必改成实际前端域名，不要用 * 或留空
CORS_ORIGIN=http://localhost:3000

JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=8h

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=tms
DB_PASSWORD=tms
# 本地开发用 true 快速迭代表结构；预发/生产必须设为 false 并改用 npm run migration:run 管理schema
DB_DATABASE=tms
DB_SYNCHRONIZE=true

REDIS_HOST=localhost
REDIS_PORT=6379

STORAGE_DRIVER=minio
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=tmsadmin
STORAGE_SECRET_KEY=tmsadmin123
STORAGE_BUCKET=tms-files

# 企业现有SMTP服务器；留空 SMTP_HOST 时邮件模块只打印日志、不会真实发送(方便本地开发)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=汽车物流TMS
SMTP_FROM_EMAIL=

# 前端实际访问地址，用于找回密码邮件里拼重置链接
FRONTEND_URL=http://localhost:3000
